# Docker environment configuration
# This file is used by docker-compose.yml

# Database (PostgreSQL in container)
DATABASE_URL=postgresql://ticket_user:ticket_password@postgres:5432/ticket_booking

# App
APP_NAME=Ticket Booking System
APP_VERSION=0.1.0
DEBUG=True

# Hold expiry
HOLD_EXPIRY_MINUTES=5

# Background scheduler
SCHEDULER_ENABLED=True
SCHEDULER_HOLD_CLEANUP_INTERVAL_SECONDS=60
